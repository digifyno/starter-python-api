APP_NAME=FastAPI Starter
# Set DEBUG=true in development to enable interactive API docs (/docs, /redoc)
# In production, keep DEBUG=false to disable docs for security
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters — shorter values cause a startup ValidationError
SECRET_KEY=change-me-generate-with-secrets-token-hex-32
# Comma-separated JSON list of allowed CORS origins. Wildcard (*) requires explicit opt-in.
# Example: ALLOWED_ORIGINS=["http://localhost:3000","https://myapp.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["yourdomain.com","www.yourdomain.com"]

# Database URL (asyncpg format for PostgreSQL async driver)
# Generate: postgresql+asyncpg://user:password@localhost/dbname
# Leave unset to skip database table creation on startup
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/dbname
